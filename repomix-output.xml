create_file("core/shell_engine.py", """
import sys
import subprocess
import threading
import queue
import time

class PersistentShell:
    def __init__(self):
        cmd = ["powershell.exe", "-NoExit", "-Command", "$OutputEncoding = [System.Text.Encoding]::UTF8"] if sys.platform == "win32" else ["/bin/bash", "--login"]
        self.proc = subprocess.Popen(cmd, stdin=subprocess.PIPE, stdout=subprocess.PIPE, stderr=subprocess.STDOUT, text=True, bufsize=1)
        self.q = queue.Queue()
        threading.Thread(target=self._read, daemon=True).start()

    def _read(self):
        while True:
            line = self.proc.stdout.readline()
            if not line: break
            self.q.put(line)

    def execute_command(self, cmd_str: str) -> str:
        self.proc.stdin.write(cmd_str + "\\n")
        self.proc.stdin.flush()
        time.sleep(0.25)
        lines = []
        while not self.q.empty(): lines.append(self.q.get_nowait())
        return "".join(lines)
""")

